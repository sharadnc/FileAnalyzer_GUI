# Copy to .env and edit paths for your machine.
# Relative paths are resolved from the project root (folder containing pyproject.toml).

WINDOW_TITLE=File Analyzer

# Python interpreter for run_file_analyzer.bat (Windows: .venv/Scripts/python.exe)
VENV_PYTHON=.venv/Scripts/python.exe

# Sample data shipped with the repo (add your own under sample/ or data/)
DEFAULT_DATA_PATH=sample/LoanPop_small.txt
# Metadata: text *_Meta, or Excel .xlsx/.xls (e.g. templates/LoanPop.xlsx)
# Leave blank to derive: <data_filename>_Meta
DEFAULT_META_PATH=

# PAGE_SIZE_DEFAULT=100
# QUICK_STATS_TOP_N=15
# QUICK_STATS_MAX_WORKERS=8
# DUCKDB_THREADS=
# DUCKDB_STORAGE_MODE=file
# TEMP_BASE_DIR=
